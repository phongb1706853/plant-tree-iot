{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "PlantTreeIoTServer/Dockerfile"
  },
  "deploy": {
    "startCommand": "dotnet PlantTreeIoTServer.dll",
    "healthcheckPath": "/api/devices",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
