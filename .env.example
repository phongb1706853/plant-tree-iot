# Copy file nay thanh .env va dien thong tin thuc

# MongoDB - tu dong inject boi Railway MongoDB plugin
# MONGODB_URL=mongodb://user:pass@host:port/dbname

# .NET
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:${PORT:-80}

# Docker Compose (local dev only)
COMPOSE_PROJECT_NAME=planttree-iot
MONGO_INITDB_DATABASE=PlantTreeIoT
HTTP_PORT=8080
HTTPS_PORT=8443
MONGO_PORT=27017
